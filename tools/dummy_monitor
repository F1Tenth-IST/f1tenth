# xorg.conf file on /etc/X11 for dummy monitor on jetson

Section "Device"
    Identifier "NVIDIA GPU"
    Driver "nvidia"
    Option "AllowEmptyInitialConfiguration" "true"
    Option "ConnectedMonitor" "DFP-0"
EndSection

Section "Monitor"
    Identifier "Monitor0"
    VendorName "FakeMonitor"
    ModelName "VirtualDisplay"
    Option "PreferredMode" "1920x1080"
    HorizSync 30.0 - 110.0
    VertRefresh 50.0 - 150.0
    Modeline "1920x1080" 148.50 1920 2008 2052 2200 1080 1084 1089 1125 +Hsync +Vsync
EndSection

Section "Screen"
    Identifier "Screen0"
    Device "NVIDIA GPU"
    Monitor "Monitor0"
    DefaultDepth 24
    SubSection "Display"
        Depth 24
        Modes "1920x1080"
    EndSubSection
EndSection
